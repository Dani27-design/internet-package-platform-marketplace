{
  "name": "internet-package-marketplace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "api": "json-server --watch db.json --port 3101",
    "typecheck": "tsc -b",
    "validate:data": "node scripts/validate-data.mjs",
    "validate:routes": "node scripts/validate-routes.mjs",
    "validate:customer": "node scripts/validate-customer.mjs",
    "validate:seller": "node scripts/validate-seller.mjs",
    "validate:responsive": "node scripts/validate-responsive.mjs",
    "validate:design-system": "node scripts/validate-design-system.mjs"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^6.1.6",
    "@tanstack/react-query": "^5.59.16",
    "json-server": "^1.0.0-beta.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.8.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
